<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootSignup"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/bg_circle_caramel"
            android:gravity="center"
            android:text="NF"
            android:textColor="@color/soft_white"
            android:textSize="24sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="Create your account"
            android:textColor="@color/soft_white"
            android:textSize="32sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Every new account starts with 0 Coffee Beans."
            android:textColor="@color/muted_text"/>

        <EditText
            android:id="@+id/edtName"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_input"
            android:hint="Full name"
            android:inputType="textPersonName"
            android:paddingHorizontal="16dp"
            android:textColor="@color/soft_white"
            android:textColorHint="@color/muted_text"/>

        <EditText
            android:id="@+id/edtEmail"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="Email address"
            android:inputType="textEmailAddress"
            android:paddingHorizontal="16dp"
            android:textColor="@color/soft_white"
            android:textColorHint="@color/muted_text"/>

        <EditText
            android:id="@+id/edtPhone"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="Phone number"
            android:inputType="phone"
            android:paddingHorizontal="16dp"
            android:textColor="@color/soft_white"
            android:textColorHint="@color/muted_text"/>

        <EditText
            android:id="@+id/edtPassword"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="Password"
            android:inputType="textPassword"
            android:paddingHorizontal="16dp"
            android:textColor="@color/soft_white"
            android:textColorHint="@color/muted_text"/>

        <EditText
            android:id="@+id/edtConfirmPassword"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="Confirm password"
            android:inputType="textPassword"
            android:paddingHorizontal="16dp"
            android:textColor="@color/soft_white"
            android:textColorHint="@color/muted_text"/>

        <TextView
            android:id="@+id/txtError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/danger_red"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/btnSignup"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_button_primary"
            android:gravity="center"
            android:text="Sign up"
            android:textColor="@color/soft_white"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/btnGoLogin"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:gravity="center"
            android:text="Already have an account? Log in"
            android:textColor="@color/cream"
            android:textStyle="bold"/>
    </LinearLayout>
</ScrollView>