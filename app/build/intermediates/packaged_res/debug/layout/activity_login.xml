<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLogin"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/bg_circle_caramel"
            android:gravity="center"
            android:text="NF"
            android:textColor="@color/soft_white"
            android:textSize="24sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="34dp"
            android:text="Welcome back"
            android:textColor="@color/soft_white"
            android:textSize="34sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Log in to order faster, use Coffee Beans, and track your orders."
            android:textColor="@color/muted_text"
            android:textSize="15sp"/>

        <EditText
            android:id="@+id/edtEmail"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="34dp"
            android:background="@drawable/bg_input"
            android:hint="Email address"
            android:inputType="textEmailAddress"
            android:paddingHorizontal="16dp"
            android:textColor="@color/soft_white"
            android:textColorHint="@color/muted_text"/>

        <EditText
            android:id="@+id/edtPassword"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input"
            android:hint="Password"
            android:inputType="textPassword"
            android:paddingHorizontal="16dp"
            android:textColor="@color/soft_white"
            android:textColorHint="@color/muted_text"/>

        <TextView
            android:id="@+id/txtError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/danger_red"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_button_primary"
            android:gravity="center"
            android:text="Log in"
            android:textColor="@color/soft_white"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/btnGoSignup"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:gravity="center"
            android:text="New here? Create account"
            android:textColor="@color/cream"
            android:textStyle="bold"/>
    </LinearLayout>
</ScrollView>