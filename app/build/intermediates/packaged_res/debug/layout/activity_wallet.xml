<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient"
    android:fitsSystemWindows="true"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Back button -->
        <TextView
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_card_dark_small"
            android:gravity="center"
            android:text="‹"
            android:textColor="@color/cream"
            android:textSize="34sp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Wallet"
            android:textColor="@color/soft_white"
            android:textSize="30sp"
            android:textStyle="bold"/>

        <!-- Balance card -->
        <TextView
            android:id="@+id/txtWalletBalance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_card_dark"
            android:gravity="center"
            android:padding="24dp"
            android:text="Rs. 0"
            android:textColor="@color/caramel"
            android:textSize="36sp"
            android:textStyle="bold"/>

        <!-- Top-up amount input -->
        <EditText
            android:id="@+id/edtTopUpAmount"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_input"
            android:hint="Enter amount (Rs. 100 - 10,000)"
            android:inputType="number"
            android:paddingHorizontal="16dp"
            android:textColor="@color/soft_white"
            android:textColorHint="@color/muted_text"/>

        <TextView
            android:id="@+id/txtAmountError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/danger_red"
            android:visibility="gone"/>

        <!-- Card details header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Card Details"
            android:textColor="@color/cream"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <!-- Card form (always visible) -->
        <LinearLayout
            android:id="@+id/cardForm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_card_dark"
            android:orientation="vertical"
            android:padding="16dp">

            <EditText
                android:id="@+id/edtCardHolder"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_input"
                android:hint="Card holder name"
                android:inputType="textPersonName"
                android:paddingHorizontal="16dp"
                android:textColor="@color/soft_white"
                android:textColorHint="@color/muted_text"/>

            <EditText
                android:id="@+id/edtCardNumber"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input"
                android:digits="0123456789 "
                android:hint="1234 5678 9876 5432"
                android:inputType="number"
                android:maxLength="19"
                android:paddingHorizontal="16dp"
                android:textColor="@color/soft_white"
                android:textColorHint="@color/muted_text"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/edtExpiry"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_input"
                    android:digits="0123456789/"
                    android:hint="07/27"
                    android:inputType="phone"
                    android:maxLength="5"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/soft_white"
                    android:textColorHint="@color/muted_text"/>

                <EditText
                    android:id="@+id/edtCvv"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_input"
                    android:hint="CVV"
                    android:inputType="numberPassword"
                    android:maxLength="3"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/soft_white"
                    android:textColorHint="@color/muted_text"/>
            </LinearLayout>

            <TextView
                android:id="@+id/txtCardError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/danger_red"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Top Up button -->
        <TextView
            android:id="@+id/btnTopUp"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_button_primary"
            android:gravity="center"
            android:text="Top Up Wallet"
            android:textColor="@color/soft_white"
            android:textSize="18sp"
            android:textStyle="bold"/>

    </LinearLayout>
</ScrollView>