<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="152dp"
    android:layout_height="168dp"
    android:layout_marginEnd="12dp"
    android:background="@drawable/bg_card_dark"
    android:orientation="vertical"
    android:padding="12dp">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="@drawable/no_filter_placeholder" />

    <TextView
        android:id="@+id/txtName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:maxLines="1"
        android:textColor="@color/cream"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtPrice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/muted_text" />

    <!-- "+" Add Button -->
    <TextView
        android:id="@+id/btnAdd"
        android:layout_width="match_parent"
        android:layout_height="34dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_button_primary"
        android:gravity="center"
        android:text="Add"
        android:textColor="@color/button_primary_text"
        android:textStyle="bold" />

    <!-- Quantity Selector -->
    <LinearLayout
        android:id="@+id/quantitySelector"
        android:layout_width="match_parent"
        android:layout_height="34dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_card_dark_small"
        android:gravity="center"
        android:orientation="horizontal"
        android:visibility="gone">

        <ImageView
            android:id="@+id/btnDelete"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:padding="4dp"
            android:src="@android:drawable/ic_menu_delete"
            android:tint="@color/danger_red"
            android:visibility="gone" />

        <TextView
            android:id="@+id/btnMinus"
            android:layout_width="28dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="−"
            android:textColor="@color/caramel"
            android:textSize="18sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvQuantity"
            android:layout_width="28dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="1"
            android:textColor="@color/cream"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnPlus"
            android:layout_width="28dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="+"
            android:textColor="@color/caramel"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>