<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootProduct"
    android:layout_width="match_parent"
    android:layout_height="132dp"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_card_dark"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="12dp">

    <ImageView
        android:layout_width="86dp"
        android:layout_height="86dp"
        android:background="@drawable/no_filter_placeholder" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:text="New"
            android:textColor="@color/soft_white"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/txtName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:maxLines="1"
            android:text="Spanish Latte"
            android:textColor="@color/cream"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:maxLines="2"
            android:text="desc"
            android:textColor="@color/muted_text"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/txtPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="from Rs. 695"
            android:textColor="@color/caramel"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- "+" Add Button -->
    <TextView
        android:id="@+id/btnAdd"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:background="@drawable/bg_circle_caramel"
        android:gravity="center"
        android:text="+"
        android:textColor="@color/button_primary_text"
        android:textSize="26sp"
        android:textStyle="bold" />

    <!-- Quantity Selector -->
    <LinearLayout
        android:id="@+id/quantitySelector"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:background="@drawable/bg_card_dark_small"
        android:gravity="center"
        android:orientation="horizontal"
        android:visibility="gone">

        <ImageView
            android:id="@+id/btnDelete"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="6dp"
            android:src="@android:drawable/ic_menu_delete"
            android:tint="@color/danger_red"
            android:visibility="gone" />

        <TextView
            android:id="@+id/btnMinus"
            android:layout_width="32dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="−"
            android:textColor="@color/caramel"
            android:textSize="20sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvQuantity"
            android:layout_width="28dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="1"
            android:textColor="@color/cream"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnPlus"
            android:layout_width="32dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="+"
            android:textColor="@color/caramel"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>