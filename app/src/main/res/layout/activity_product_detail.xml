<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootProductDetail"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_card_dark_small"
            android:gravity="center"
            android:text="‹"
            android:textColor="@color/cream"
            android:textSize="34sp"/>

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="210dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/no_filter_placeholder"/>

        <TextView
            android:id="@+id/txtName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:textColor="@color/soft_white"
            android:textSize="30sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/txtDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/muted_text"/>

        <TextView
            android:id="@+id/txtCustomizeTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Customize"
            android:textColor="@color/cream"
            android:textSize="20sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/txtSize"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:textColor="@color/soft_white"/>

        <TextView
            android:id="@+id/txtSweetness"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:textColor="@color/soft_white"/>

        <TextView
            android:id="@+id/txtIce"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:textColor="@color/soft_white"/>

        <TextView
            android:id="@+id/txtFoodNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Ready to add to your cart."
            android:textColor="@color/muted_text"/>

        <!-- Original price & discount -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtOriginalPriceDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rs. 1300"
                android:textColor="@color/muted_text"
                android:textSize="16sp"
                android:visibility="gone"
                android:paddingEnd="8dp"/>

            <TextView
                android:id="@+id/txtDiscountPercent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_discount"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="Save 20%"
                android:textColor="@color/soft_white"
                android:textSize="14sp"
                android:visibility="gone"/>
        </LinearLayout>

        <TextView
            android:id="@+id/txtRequiredWarning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Select size, sweetness and ice first."
            android:textColor="@color/danger_red"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/btnAddToCart"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_button_primary"
            android:gravity="center"
            android:textColor="@color/soft_white"
            android:textSize="18sp"
            android:textStyle="bold"/>
    </LinearLayout>
</ScrollView>